# Frontend Environment Variables

# For Local Development
VITE_API_URL=http://localhost:8000

# For Production Deployment
# VITE_API_URL=https://agent-emily.onrender.com

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Contact / invite forms (SMTP via Vercel serverless: frontend/api/contact.js) ---
# Production on Vercel: leave unset → browser uses same-origin /api/contact. Set SMTP_* in Vercel project env.
# Local dev: set full URL below — the app uses /api/contact + Vite proxies to this host (no CORS issues).
# VITE_CONTACT_API_URL=https://your-domain.vercel.app/api/contact

# Optional: Formspree instead of /api/contact (set both)
# VITE_CONTACT_USE_FORMSPREE=true
# VITE_FORMSPREE_FORM_ID=your_formspree_form_id_here

# Contact page – office address (use | between lines; defaults are set in ContactUsPage.jsx)
# VITE_COMPANY_ADDRESS=Gala Magnus, 314|Safal Parisar Rd, South Bopal, Bopal|Ahmedabad, Gujarat 380057|India
# Map: search query for embed + “Open in Google Maps” link
# VITE_MAP_QUERY=Gala Magnus, 314, Safal Parisar Rd, South Bopal, Bopal, Ahmedabad, Gujarat 380057, India
# Optional: paste full iframe src from Google Maps → Share → Embed map (overrides query-based embed)
# VITE_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=...
